{{-- ████████████████████████████████████████████████████████████
     JAVASCRIPT
████████████████████████████████████████████████████████████ --}}
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

<script>
(function () {
    'use strict';

    /* ══════════════════════════════════════════════════════════
       COVER PARTICLE SYSTEM — Gold dust floating up
    ══════════════════════════════════════════════════════════ */
    var coverCanvas = document.getElementById('al-particles');
    var ctx = coverCanvas ? coverCanvas.getContext('2d') : null;
    var W, H, particles = [];

    function resizeCoverCanvas() {
        if (!coverCanvas) return;
        W = coverCanvas.width  = window.innerWidth;
        H = coverCanvas.height = window.innerHeight;
    }

    function GoldParticle(init) {
        this.reset = function(fresh) {
            this.x    = Math.random() * W;
            this.y    = fresh ? H + Math.random() * 40 : Math.random() * H;
            this.r    = 0.5 + Math.random() * 1.8;
            this.vy   = -(0.25 + Math.random() * 0.6);
            this.vx   = (Math.random() - 0.5) * 0.25;
            this.a    = 0;
            this.aMax = 0.5 + Math.random() * 0.4;
            this.life = 0;
            this.lifeMax = 180 + Math.random() * 200;
            /* slight sparkle */
            this.twinkle = Math.random() > 0.5;
            this.tSpeed  = 0.03 + Math.random() * 0.05;
            this.tPhase  = Math.random() * Math.PI * 2;
        };
        this.reset(init);
    }

    function initCoverParticles() {
        if (!ctx) return;
        resizeCoverCanvas();
        particles = [];
        for (var i = 0; i < 60; i++) { particles.push(new GoldParticle(false)); }
        window.addEventListener('resize', resizeCoverCanvas, { passive: true });
        animCoverParticles();
    }

    function animCoverParticles() {
        if (!ctx) return;
        ctx.clearRect(0, 0, W, H);
        var now = Date.now() * 0.001;
        for (var i = 0; i < particles.length; i++) {
            var p = particles[i];
            p.life++;
            if (p.life > p.lifeMax) { p.reset(true); continue; }

            p.x += p.vx;
            p.y += p.vy;
            /* fade in/out */
            if (p.life < 30)       p.a = Math.min(p.aMax, p.a + p.aMax / 30);
            else if (p.life > p.lifeMax - 30) p.a = Math.max(0, p.a - p.aMax / 30);

            var alpha = p.a;
            if (p.twinkle) alpha *= 0.6 + 0.4 * Math.sin(now * p.tSpeed * 60 + p.tPhase);

            /* gold gradient dot */
            var grd = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 2);
            grd.addColorStop(0,   'rgba(237,216,138,' + alpha + ')');
            grd.addColorStop(0.5, 'rgba(212,175,55,' + alpha * 0.7 + ')');
            grd.addColorStop(1,   'rgba(212,175,55,0)');
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.r * 2, 0, Math.PI * 2);
            ctx.fillStyle = grd;
            ctx.fill();
        }
        requestAnimationFrame(animCoverParticles);
    }

    initCoverParticles();

    /* ══════════════════════════════════════════════════════════
       AMBIENT PARTICLE SYSTEM — Shown after opening
    ══════════════════════════════════════════════════════════ */
    var ambCanvas = document.getElementById('al-ambient-canvas');
    var ambCtx = ambCanvas ? ambCanvas.getContext('2d') : null;
    var AW, AH, ambParticles = [], ambRunning = false;

    function resizeAmbCanvas() {
        if (!ambCanvas) return;
        AW = ambCanvas.width  = window.innerWidth;
        AH = ambCanvas.height = window.innerHeight;
    }

    function AmbParticle() {
        this.reset = function(fresh) {
            this.x    = Math.random() * AW;
            this.y    = fresh ? AH + Math.random() * 30 : Math.random() * AH;
            this.r    = 0.4 + Math.random() * 1.4;
            this.vy   = -(0.15 + Math.random() * 0.35);
            this.vx   = (Math.random() - 0.5) * 0.18;
            this.a    = 0;
            this.aMax = 0.3 + Math.random() * 0.25;
            this.life = 0;
            this.lifeMax = 220 + Math.random() * 240;
        };
        this.reset(false);
    }

    function startAmbientParticles() {
        if (ambRunning || !ambCtx) return;
        ambRunning = true;
        if (ambCanvas) ambCanvas.style.display = 'block';
        resizeAmbCanvas();
        ambParticles = [];
        for (var i = 0; i < 35; i++) { ambParticles.push(new AmbParticle()); }
        window.addEventListener('resize', resizeAmbCanvas, { passive: true });
        loopAmb();
    }

    function loopAmb() {
        if (!ambCtx) return;
        ambCtx.clearRect(0, 0, AW, AH);
        for (var i = 0; i < ambParticles.length; i++) {
            var p = ambParticles[i];
            p.life++;
            if (p.life > p.lifeMax) { p.reset(true); continue; }
            p.x += p.vx; p.y += p.vy;
            if (p.life < 40)       p.a = Math.min(p.aMax, p.a + p.aMax / 40);
            else if (p.life > p.lifeMax - 40) p.a = Math.max(0, p.a - p.aMax / 40);
            var grd = ambCtx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 2.5);
            grd.addColorStop(0,   'rgba(237,216,138,' + p.a + ')');
            grd.addColorStop(0.6, 'rgba(212,175,55,' + p.a * 0.5 + ')');
            grd.addColorStop(1,   'rgba(212,175,55,0)');
            ambCtx.beginPath();
            ambCtx.arc(p.x, p.y, p.r * 2.5, 0, Math.PI * 2);
            ambCtx.fillStyle = grd;
            ambCtx.fill();
        }
        requestAnimationFrame(loopAmb);
    }

    /* ══════════════════════════════════════════════════════════
       MOORISH GATE OPENING
       Note: we do NOT use data-coi-* attributes. This template
       has its own self-contained gate system (like jawa-exclusive).
       cinematic-opening.blade.php is only included for its Lenis /
       ScrollTrigger scroll-reveal helpers — it won't intercept our
       button because [data-coi-btn] is absent from this template.
    ══════════════════════════════════════════════════════════ */
    var openBtn  = document.getElementById('al-open-btn');
    var doorL    = document.getElementById('al-door-l');
    var doorR    = document.getElementById('al-door-r');
    var cover    = document.getElementById('al-cover');
    var content  = document.getElementById('al-cover-content');
    var mainEl   = document.getElementById('al-main');
    var opened   = false;

    /* ── CSS-level reveal (no GSAP dependency) ─────────────── */
    function revealMain() {
        if (!mainEl) return;
        mainEl.style.transition = 'opacity 0.65s ease';
        mainEl.style.opacity    = '1';
        mainEl.classList.add('visible');
        /* Fade in bottom navbar after gate is fully open */
        setTimeout(function () {
            var bn = document.getElementById('al-bottom-nav');
            if (bn) { bn.style.opacity = '1'; bn.style.pointerEvents = 'auto'; }
        }, 500);
    }

    /* ── Gold geometric burst — fires from seam as gate opens ── */
    function spawnAndalusiaReveal() {
        var bc  = document.createElement('canvas');
        bc.style.cssText = 'position:fixed;inset:0;z-index:300;pointer-events:none;';
        bc.width  = window.innerWidth;
        bc.height = window.innerHeight;
        document.body.appendChild(bc);

        var bx   = bc.getContext('2d');
        var cx   = bc.width  / 2;
        var cy   = bc.height / 2;
        var DURATION = 1600; // ms
        var start    = null;

        /* Build burst particles radiating from seam center */
        var burst = [];
        var COUNT = 55;
        for (var i = 0; i < COUNT; i++) {
            var angle = (Math.PI * 2 / COUNT) * i + (Math.random() - 0.5) * 0.18;
            var spd   = 1.8 + Math.random() * 4.5;
            burst.push({
                vx:    Math.cos(angle) * spd,
                vy:    Math.sin(angle) * spd,
                r:     1.2 + Math.random() * 2.5,
                type:  i % 3 === 0 ? 'diamond' : 'circle',
                delay: Math.random() * 180   /* stagger */
            });
        }

        /* Also add a central flash ring */
        var flashDone = false;

        function drawDiamond(ctx, x, y, r) {
            ctx.beginPath();
            ctx.moveTo(x,       y - r);
            ctx.lineTo(x + r * 0.55, y);
            ctx.lineTo(x,       y + r);
            ctx.lineTo(x - r * 0.55, y);
            ctx.closePath();
        }

        function animBurst(ts) {
            if (!start) start = ts;
            var elapsed = ts - start;
            var progress = Math.min(elapsed / DURATION, 1);

            bx.clearRect(0, 0, bc.width, bc.height);

            /* Flash ring — fast expand + fade */
            if (!flashDone) {
                var fp = Math.min(elapsed / 400, 1);
                var fr = fp * Math.min(bc.width, bc.height) * 0.55;
                var fa = (1 - fp) * 0.45;
                if (fa > 0) {
                    bx.beginPath();
                    bx.arc(cx, cy, fr, 0, Math.PI * 2);
                    bx.strokeStyle = 'rgba(212,175,55,' + fa + ')';
                    bx.lineWidth   = 2;
                    bx.stroke();
                }
                if (fp >= 1) flashDone = true;
            }

            /* Burst particles */
            for (var i = 0; i < burst.length; i++) {
                var p = burst[i];
                if (elapsed < p.delay) continue;
                var pe = elapsed - p.delay;
                var t  = pe * 0.001;          /* seconds since particle born */
                var pp = Math.min(pe / (DURATION - p.delay), 1);

                /* ease out: slow down over time */
                var eased = 1 - Math.pow(1 - pp, 2);
                var px = cx + p.vx * eased * 220;
                var py = cy + p.vy * eased * 220;

                /* fade in fast, hold, then fade out */
                var alpha;
                if (pp < 0.15)      alpha = pp / 0.15;
                else if (pp < 0.65) alpha = 1;
                else                alpha = 1 - (pp - 0.65) / 0.35;
                alpha = Math.max(0, alpha) * 0.82;

                bx.globalAlpha = alpha;
                bx.fillStyle   = '#D4AF37';

                if (p.type === 'diamond') {
                    drawDiamond(bx, px, py, p.r * (1 + eased * 0.6));
                    bx.fill();
                } else {
                    bx.beginPath();
                    bx.arc(px, py, p.r, 0, Math.PI * 2);
                    bx.fill();
                }
            }

            bx.globalAlpha = 1;

            if (progress < 1) {
                requestAnimationFrame(animBurst);
            } else {
                bc.parentNode && bc.parentNode.removeChild(bc);
            }
        }

        requestAnimationFrame(animBurst);
    }

    function onOpenComplete() {
        spawnAndalusiaReveal();           /* Gold burst from seam */
        if (cover) cover.style.display = 'none';
        revealMain();
        startAmbientParticles();
        /* Autoplay music if enabled — user gesture from open button allows this */
        if (window._musicAutoplay) {
            var store = window.Alpine && window.Alpine.store('invitation');
            if (store && !store.musicPlaying) store.toggleMusic();
        }
        /* Refresh AOS after a tick so layout is stable, then init parallax */
        setTimeout(function () {
            if (typeof AOS !== 'undefined') { AOS.refresh(); }
            initScrollAnimations();
        }, 80);
    }

    if (openBtn) {
        openBtn.addEventListener('click', function () {
            if (opened) return;
            opened = true;

            /* ─ GSAP path (premium animation) ─ */
            if (typeof gsap !== 'undefined') {
                if (typeof ScrollTrigger !== 'undefined') {
                    gsap.registerPlugin(ScrollTrigger);
                }

                var tl = gsap.timeline({ onComplete: onOpenComplete });

                /* 1. Button scale feedback */
                tl.to(openBtn, { scale: 0.92, duration: 0.1, ease: 'power2.out' });

                /* 2. Cover text fades out */
                tl.to(content, {
                    opacity: 0, y: -18,
                    duration: 0.5, ease: 'power2.in'
                }, 0.05);

                /* 3. GATE SLIDING — left and right simultaneously */
                tl.to(doorL, {
                    x: '-102%', rotation: -3, scale: 0.97,
                    duration: 1.55, ease: 'expo.inOut'
                }, 0.5);
                tl.to(doorR, {
                    x: '102%', rotation: 3, scale: 0.97,
                    duration: 1.55, ease: 'expo.inOut'
                }, 0.5);

                /* 5. Cover fades out */
                tl.to(cover, {
                    opacity: 0, duration: 0.5, ease: 'power2.inOut'
                }, 1.6);

                /* 7. Main content fades in (CSS transition, not GSAP) */
                tl.add(function () { revealMain(); }, 1.75);

            } else {
                /* ─ CSS-only fallback (no GSAP) ─ */
                if (content) content.style.transition = 'opacity 0.4s';
                if (content) content.style.opacity    = '0';

                /* Slide gates with CSS transitions */
                if (doorL) {
                    doorL.style.transition = 'transform 1.4s cubic-bezier(0.76,0,0.24,1)';
                    doorL.style.transform  = 'translateX(-102%)';
                }
                if (doorR) {
                    doorR.style.transition = 'transform 1.4s cubic-bezier(0.76,0,0.24,1)';
                    doorR.style.transform  = 'translateX(102%)';
                }
                setTimeout(function () {
                    if (cover) { cover.style.transition = 'opacity 0.5s'; cover.style.opacity = '0'; }
                    setTimeout(onOpenComplete, 520);
                }, 1500);
            }
        });
    }

    /* ══════════════════════════════════════════════════════════
       SCROLL ANIMATIONS — Hero parallax only.
       NOTE: Section content (event cards, photos, gallery) is
       animated by AOS. Do NOT add gsap.from() on those elements
       — AOS sets [data-aos^="fade"] to opacity:0 via CSS, so
       gsap.from({opacity:0}) would read 0 as the "to" state and
       keep elements permanently invisible.
    ══════════════════════════════════════════════════════════ */
    function initScrollAnimations() {
        if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;

        /* Hero parallax — layer 2 (medallion SVG) */
        var layer2 = document.getElementById('al-hero-layer2');
        if (layer2) {
            gsap.to(layer2, {
                yPercent: -25,
                ease: 'none',
                scrollTrigger: {
                    trigger: '#nav-top',
                    start: 'top top',
                    end:   'bottom top',
                    scrub: true
                }
            });
        }

        /* Hero parallax — layer 3 (text content) */
        var layer3 = document.getElementById('al-hero-layer3');
        if (layer3) {
            gsap.to(layer3, {
                yPercent: -12,
                ease: 'none',
                scrollTrigger: {
                    trigger: '#nav-top',
                    start: 'top top',
                    end:   'bottom top',
                    scrub: 1.5
                }
            });
        }

        /* Footer medallion gentle float */
        var footer = document.getElementById('nav-footer');
        if (footer) {
            gsap.from(footer.querySelector('svg'), {
                yPercent: 15,
                ease: 'none',
                scrollTrigger: {
                    trigger: footer,
                    start: 'top bottom',
                    end:   'top top',
                    scrub: 2
                }
            });
        }
    }

    /* ══════════════════════════════════════════════════════════
       AOS INIT
    ══════════════════════════════════════════════════════════ */
    document.addEventListener('DOMContentLoaded', function () {
        if (typeof AOS !== 'undefined') {
            AOS.init({
                duration: 800,
                easing: 'ease-out-quart',
                once: true,
                offset: 60,
                disable: false
            });
        }
    });

}());
</script>

{{-- NOTE: @livewireScripts is intentionally omitted here.
     app.js imports Livewire ESM and calls Livewire.start() explicitly.
     Loading @livewireScripts here would create a second Alpine instance. --}}

</body>
</html>
