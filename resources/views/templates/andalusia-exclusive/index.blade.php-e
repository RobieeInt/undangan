    <button @click="$store.invitation.toggleMusic()"
            style="width:44px;height:44px;border-radius:50%;background:rgba(10,31,11,0.9);border:1px solid rgba(212,175,55,0.4);color:#D4AF37;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 20px rgba(0,0,0,0.4)">
        <svg x-show="!$store.invitation.musicPlaying" width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
