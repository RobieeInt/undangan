                                 style="width:100%;display:block;border:1px solid rgba(212,175,55,0.2);border-radius:2px">
                        </div>
                        <p class="ff-poppins" style="font-size:0.7rem;color:var(--al-muted);margin-top:0.6rem;letter-spacing:0.05em">
                            Scan QR untuk transfer
                        </p>
                    @else
                        {{-- ── Bank Transfer ────────────────────────────── --}}
                        <p class="ff-cinzel" style="font-size:0.55rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--al-gold2);margin-bottom:0.5rem">
                            {{ $gift->bank_name ?? 'Transfer' }}
                        </p>
                        <p class="ff-garamond" style="font-size:1.3rem;color:var(--al-emerald);margin-bottom:0.2rem">
                            {{ $gift->account_name }}
                        </p>
                        <div x-data style="display:flex;align-items:center;justify-content:center;gap:0.75rem;margin-top:0.5rem">
                            <code style="font-family:'Poppins',sans-serif;font-size:1rem;letter-spacing:0.1em;color:var(--al-text);font-weight:500">
                                {{ $gift->account_number }}
                            </code>
                            <button @click="navigator.clipboard.writeText('{{ $gift->account_number }}').then(() => { $el.textContent = '✓'; setTimeout(() => $el.textContent = 'Salin', 2000) })"
                                    style="font-family:'Cinzel',serif;font-size:0.55rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--al-gold2);background:transparent;border:1px solid rgba(212,175,55,0.35);padding:0.3rem 0.75rem;cursor:pointer">
                                Salin
                            </button>
                        </div>
                    @endif
                </div>
                @endforeach
            </div>
        </div>
    </section>
    @endif

    {{-- ── §8 WISHES ────────────────────────────────────────── --}}
    <section id="nav-wishes" class="al-section">
        <div class="al-container">

            <div style="text-align:center;margin-bottom:2.5rem" data-aos="fade-up">
                <span class="al-label">Ucapan &amp; Doa</span>
                <h3 class="ff-garamond" style="font-size:clamp(1.8rem,6vw,2.8rem);font-weight:300;color:var(--al-emerald)">
                    Pesan Untuk Kami
                </h3>
                <div style="margin-top:1rem;display:flex;align-items:center;gap:1rem;justify-content:center">
                    <div style="flex:1;max-width:100px;height:1px;background:linear-gradient(to right,transparent,rgba(212,175,55,0.4))"></div>
                    <svg width="8" height="8" viewBox="0 0 10 10"><polygon points="5,0 10,5 5,10 0,5" fill="#D4AF37" opacity="0.6"/></svg>
                    <div style="flex:1;max-width:100px;height:1px;background:linear-gradient(to left,transparent,rgba(212,175,55,0.4))"></div>
                </div>
            </div>

            <livewire:invitation.guest-wishes :invitation="$invitation" />
        </div>
    </section>

    {{-- ── §9 FOOTER ────────────────────────────────────────── --}}
    <section id="nav-footer">
        <div style="position:relative;z-index:1;text-align:center">

            {{-- Medallion ornament --}}
            <div data-aos="zoom-in" style="margin-bottom:2rem">
                <svg viewBox="0 0 100 100" fill="none" class="mx-auto" style="width:72px">
                    <circle cx="50" cy="50" r="46" stroke="#D4AF37" stroke-width="0.8" opacity="0.4"/>
                    <circle cx="50" cy="50" r="36" stroke="#D4AF37" stroke-width="0.5" opacity="0.3"/>
                    <polygon points="50,8 54,36 82,36 60,54 68,82 50,64 32,82 40,54 18,36 46,36"
                             fill="none" stroke="#D4AF37" stroke-width="0.8" opacity="0.6"/>
                    <circle cx="50" cy="50" r="8" fill="none" stroke="#D4AF37" stroke-width="0.7" opacity="0.5"/>
                    <circle cx="50" cy="50" r="3" fill="#D4AF37" opacity="0.5"/>
                </svg>
            </div>

            <p class="ff-amiri" data-aos="fade-up"
               style="font-size:1.4rem;color:rgba(212,175,55,0.8);letter-spacing:0.04em;margin-bottom:1.5rem">
                وَمِنْ آيَاتِهِ أَنْ خَلَقَ لَكُم
            </p>

            <h2 class="ff-garamond" data-aos="fade-up" data-aos-delay="100"
                style="font-size:clamp(2rem,8vw,3.5rem);font-weight:300;color:#FBF5DD;line-height:1.1;margin-bottom:1rem">
                {{ $invitation->groom_name }} &amp; {{ $invitation->bride_name }}
            </h2>

            <p class="ff-poppins" data-aos="fade-up" data-aos-delay="200"
               style="font-size:0.8rem;color:rgba(251,245,221,0.4);margin-bottom:2.5rem;line-height:1.8">
                Kami mengundang Bapak/Ibu/Saudara/i<br>untuk hadir dan memberikan doa restu.
            </p>

            {{-- Gold divider --}}
            <div data-aos="fade-up" data-aos-delay="300"
                 style="width:80px;height:1px;background:linear-gradient(to right,transparent,var(--al-gold),transparent);margin:0 auto 2rem"></div>

            @if($show_watermark ?? true)
            <p class="ff-cinzel" style="font-size:0.5rem;letter-spacing:0.35em;text-transform:uppercase;color:rgba(212,175,55,0.2)">
                Made with ❤ by Invora.id
            </p>
            @endif
        </div>
    </section>

</div>
