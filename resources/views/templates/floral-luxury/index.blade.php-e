<div id="floral-petals"></div>

@include('partials.cinematic-opening')
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({ duration: 900, once: true, offset: 50 });

    // Auto-play music if configured
    @if($invitation->music_autoplay)
    document.addEventListener('alpine:initialized', () => {
        // Will be triggered after envelope opens via store
    });
    @endif

    // ── Falling Flower Petals (cover + global canvas) ────────────
    (function () {
        var COLORS = [
            ['#fce7f3','#fbcfe8'], // blush pink
            ['#fbcfe8','#f9a8d4'], // rose pink
            ['#f9a8d4','#f472b6'], // deeper pink
            ['#fef3c7','#fde68a'], // cream yellow
            ['#dcfce7','#bbf7d0'], // light mint
            ['#ffffff','#f3f4f6'], // white
        ];

        function mkSvg(c1, c2, t) {
            if (t === 0) {
                return '<svg viewBox="0 0 20 34" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%">'
                     + '<path d="M10 1C16 9,17 22,10 33C3 22,4 9,10 1Z" fill="'+c1+'"/>'
                     + '<path d="M10 5C13 12,14 22,10 29C7 22,7 12,10 5Z" fill="'+c2+'" opacity=".45"/>'
                     + '</svg>';
            }
            if (t === 1) {
                return '<svg viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%">'
                     + '<g transform="translate(25,25)">'
                     + '<ellipse rx="6" ry="13" transform="rotate(0)"   fill="'+c1+'"/>'
                     + '<ellipse rx="6" ry="13" transform="rotate(72)"  fill="'+c1+'"/>'
                     + '<ellipse rx="6" ry="13" transform="rotate(144)" fill="'+c1+'"/>'
                     + '<ellipse rx="6" ry="13" transform="rotate(216)" fill="'+c1+'"/>'
                     + '<ellipse rx="6" ry="13" transform="rotate(288)" fill="'+c1+'"/>'
                     + '<circle r="4" fill="'+c2+'"/>'
                     + '</g></svg>';
            }
            return '<svg viewBox="0 0 30 22" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%">'
                 + '<ellipse cx="15" cy="11" rx="14" ry="8" fill="'+c1+'" transform="rotate(-25 15 11)"/>'
                 + '<ellipse cx="15" cy="11" rx="9"  ry="5" fill="'+c2+'" opacity=".5" transform="rotate(-25 15 11)"/>'
                 + '</svg>';
        }

        function spawnPetals(canvasId, N) {
            var c = document.getElementById(canvasId);
            if (!c) return;
            for (var i = 0; i < N; i++) {
                var cp    = COLORS[Math.floor(Math.random() * COLORS.length)];
                var t     = Math.floor(Math.random() * 3);
                var sz    = t === 1 ? (10 + Math.random() * 14) : (8 + Math.random() * 18);
                var dur   = 9 + Math.random() * 14;
                var drift = (Math.random() > .5 ? 1 : -1) * (30 + Math.random() * 90);
                var spin  = (Math.random() > .5 ? 1 : -1) * (300 + Math.random() * 440);
                var el    = document.createElement('div');
                el.className = 'fl-petal';
                el.style.cssText =
                    'left:'   + (Math.random() * 100) + '%;'
                  + 'top:-80px;'
                  + 'width:'  + sz + 'px;'
                  + 'height:' + (t === 1 ? sz : sz * 1.5) + 'px;'
                  + '--drift:' + drift + 'px;'
                  + '--spin:'  + spin  + 'deg;'
                  + 'animation:flPetalFall ' + dur + 's linear ' + (-(Math.random() * dur)) + 's infinite;';
                el.innerHTML = mkSvg(cp[0], cp[1], t);
                c.appendChild(el);
            }
        }

        spawnPetals('fl-cover-petals', 22); // cover screen (absolute inside cover div)
        spawnPetals('floral-petals',   26); // main content overlay (fixed z-92)
    })();
</script>
</body>
</html>
