<script>
for(let i=0;i<30;i++){
 let d=document.createElement('div');
 d.className='particle';
 d.style.left=Math.random()*100+'%';
 d.style.animationDelay=Math.random()*18+'s';
 document.body.appendChild(d);
}
</script>
