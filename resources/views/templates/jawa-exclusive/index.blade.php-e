{{-- ═══════════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════════ --}}
<script>
/* ── JASMINE PETAL PARTICLE SYSTEM ── */
(function () {
    const canvas = document.getElementById('je-petals');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let W, H, RAF, particles = [];

    function resize() {
        W = canvas.width  = window.innerWidth;
        H = canvas.height = window.innerHeight;
    }

    function Particle() {
        this.reset = function (fresh) {
            this.x   = Math.random() * W;
            this.y   = fresh ? -12 : Math.random() * H;
            this.vy  = .35 + Math.random() * .55;
            this.vx  = (Math.random() - .5) * .5;
            this.r   = 2.5 + Math.random() * 3;
            this.o   = .2 + Math.random() * .45;
            this.rot = Math.random() * Math.PI * 2;
            this.dr  = (Math.random() - .5) * .022;
        };
        this.reset(false);
    }

    function drawPetal(r) {
        ctx.beginPath();
        ctx.ellipse(0, -r * .85, r * .42, r, 0, 0, Math.PI * 2);
    }

    function tick() {
        ctx.clearRect(0, 0, W, H);
        particles.forEach(p => {
            p.y   += p.vy;
            p.x   += p.vx + Math.sin(p.y * .025) * .3;
            p.rot += p.dr;
            if (p.y > H + 16) p.reset(true);

            ctx.save();
            ctx.translate(p.x, p.y);
            ctx.rotate(p.rot);
            ctx.globalAlpha = p.o;

            for (let i = 0; i < 5; i++) {
                ctx.save();
                ctx.rotate(i * Math.PI * 2 / 5);
                drawPetal(p.r);
                ctx.fillStyle = '#ffffff';
                ctx.fill();
                ctx.restore();
            }
            ctx.beginPath();
            ctx.arc(0, 0, p.r * .3, 0, Math.PI * 2);
            ctx.fillStyle = '#C9A86A';
            ctx.fill();
            ctx.restore();
        });
        RAF = requestAnimationFrame(tick);
    }

    resize();
    window.addEventListener('resize', resize);

    for (let i = 0; i < 55; i++) {
        const p = new Particle();
        particles.push(p);
    }
    tick();

    // Stop when cover closes
    document.addEventListener('alpine:init', () => {
        Alpine.effect(() => {
            if (Alpine.store && false) cancelAnimationFrame(RAF);
        });
    });
})();

/* ── DOOR-OPENING JASMINE BURST ── */
(function () {
    function jasmineFlowerSvg(sz) {
        const d = sz * 2;
        return `<svg width="${d}" height="${d}" viewBox="-10 -10 20 20" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="0" cy="-5.5" rx="3.1" ry="5.5" fill="white" opacity=".88"/>
            <ellipse cx="0" cy="-5.5" rx="3.1" ry="5.5" fill="white" opacity=".82" transform="rotate(72)"/>
            <ellipse cx="0" cy="-5.5" rx="3.1" ry="5.5" fill="white" opacity=".82" transform="rotate(144)"/>
            <ellipse cx="0" cy="-5.5" rx="3.1" ry="5.5" fill="white" opacity=".82" transform="rotate(216)"/>
            <ellipse cx="0" cy="-5.5" rx="3.1" ry="5.5" fill="white" opacity=".82" transform="rotate(288)"/>
            <circle cx="0" cy="0" r="2.1" fill="#C9A86A" opacity=".95"/>
        </svg>`;
    }

    function spawnJasmineBurst() {
        const wrap = document.createElement('div');
        wrap.style.cssText = 'position:fixed;inset:0;z-index:250;pointer-events:none;overflow:hidden';
        document.body.appendChild(wrap);

        const specs = [
            {xp:48,  yp:78, sz:18, dl:0,    ry:-18,  sw:-45},
            {xp:52,  yp:82, sz:14, dl:0.1,  ry:22,   sw:38},
            {xp:44,  yp:72, sz:12, dl:0.22, ry:-32,  sw:-30},
            {xp:56,  yp:75, sz:16, dl:0.15, ry:16,   sw:28},
            {xp:50,  yp:86, sz:10, dl:0.05, ry:-10,  sw:-18},
            {xp:42,  yp:66, sz:13, dl:0.35, ry:28,   sw:-55},
            {xp:58,  yp:68, sz:15, dl:0.28, ry:-24,  sw:48},
            {xp:47,  yp:58, sz:9,  dl:0.50, ry:38,   sw:-24},
            {xp:53,  yp:60, sz:11, dl:0.42, ry:-28,  sw:34},
            {xp:45,  yp:50, sz:13, dl:0.58, ry:14,   sw:-40},
            {xp:55,  yp:46, sz:10, dl:0.65, ry:-22,  sw:22},
            {xp:50,  yp:40, sz:12, dl:0.75, ry:32,   sw:-28},
            {xp:40,  yp:88, sz:8,  dl:0.38, ry:-42,  sw:-62},
            {xp:60,  yp:84, sz:9,  dl:0.32, ry:35,   sw:56},
            {xp:35,  yp:80, sz:7,  dl:0.55, ry:-18,  sw:-70},
            {xp:65,  yp:76, sz:8,  dl:0.48, ry:24,   sw:65},
        ];

        specs.forEach(s => {
            const el = document.createElement('div');
            el.style.cssText = [
                `position:absolute`,
                `left:${s.xp}%`,
                `top:${s.yp}%`,
                `margin-left:-${s.sz}px`,
                `margin-top:-${s.sz}px`,
                `opacity:0`,
                `will-change:transform,opacity`,
            ].join(';');
            el.innerHTML = jasmineFlowerSvg(s.sz);
            wrap.appendChild(el);

            const upDist = 120 + Math.random() * 170;
            el.animate([
                { opacity: 0, transform: `translate(0,0) rotate(0deg) scale(0.3)` },
                { opacity: 0.82, transform: `translate(${s.sw * 0.6}px,${-upDist * 0.5}px) rotate(${s.ry * 0.5}deg) scale(1)`, offset: 0.4 },
                { opacity: 0.72, transform: `translate(${s.sw}px,${-upDist}px) rotate(${s.ry}deg) scale(0.85)`, offset: 0.8 },
                { opacity: 0,    transform: `translate(${s.sw * 1.2}px,${-upDist * 1.3}px) rotate(${s.ry * 1.4}deg) scale(0.5)` },
            ], {
                duration: (2200 + Math.random() * 1400),
                delay: s.dl * 1000,
                easing: 'cubic-bezier(0.25, 0.46, 0.45, 0.94)',
                fill: 'forwards',
            });
        });

        setTimeout(() => {
            if (wrap.parentNode) wrap.parentNode.removeChild(wrap);
        }, 5500);

        // After cover fades out, start the ambient loop on the hero
        setTimeout(startAmbientJasmineHero, 1600);
    }

    /* ── AMBIENT JASMINE LOOP — gentle flowers rising over hero after open ── */
    function startAmbientJasmineHero() {
        // Prevent double-start
        if (document.getElementById('je-ambient-flowers')) return;

        const wrap = document.createElement('div');
        wrap.id = 'je-ambient-flowers';
        wrap.style.cssText =
            'position:fixed;inset:0;z-index:10;pointer-events:none;overflow:hidden;';
        document.body.appendChild(wrap);

        let batchCount = 0;
        const MAX_BATCHES = 14; // ~60s total

        function spawnBatch() {
            if (batchCount >= MAX_BATCHES) {
                setTimeout(() => {
                    if (wrap.parentNode) wrap.parentNode.removeChild(wrap);
                }, 7000);
                return;
            }
            batchCount++;

            const n = 2 + Math.floor(Math.random() * 2);
            for (let i = 0; i < n; i++) {
                const sz = 7 + Math.random() * 10;
                const el = document.createElement('div');
                const xp = 8 + Math.random() * 84;
                const yp = 68 + Math.random() * 28;
                el.style.cssText = [
                    `position:absolute`,
                    `left:${xp}%`,
                    `top:${yp}%`,
                    `opacity:0`,
                    `will-change:transform,opacity`,
                ].join(';');
                el.innerHTML = jasmineFlowerSvg(sz);
                wrap.appendChild(el);

                const upDist = 270 + Math.random() * 260;
                const sw     = (Math.random() - 0.5) * 58;
                const rx     = (Math.random() - 0.5) * 65;
                el.animate([
                    { opacity: 0, transform: `translate(0,0) rotate(0deg) scale(0.35)` },
                    { opacity: 0.68, transform: `translate(${sw*.4}px,${-upDist*.45}px) rotate(${rx*.4}deg) scale(1)`, offset: 0.4 },
                    { opacity: 0.48, transform: `translate(${sw*.75}px,${-upDist*.78}px) rotate(${rx*.75}deg) scale(0.85)`, offset: 0.75 },
                    { opacity: 0,   transform: `translate(${sw}px,${-upDist}px) rotate(${rx}deg) scale(0.5)` },
                ], {
                    duration: 4800 + Math.random() * 2800,
                    delay: Math.random() * 600,
                    easing: 'cubic-bezier(0.25,0.46,0.45,0.94)',
                    fill: 'forwards',
                });

                setTimeout(() => {
                    if (el.parentNode) el.parentNode.removeChild(el);
                }, 9000);
            }

            setTimeout(spawnBatch, 4200 + Math.random() * 2000);
        }

        spawnBatch();
    }

    // Watch for door open click
    document.addEventListener('click', e => {
        if (e.target.closest('.je-open-btn')) {
            setTimeout(spawnJasmineBurst, 150);
        }
    }, { once: true });
})();

/* ── SCROLL REVEAL ── */
(function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const io = new IntersectionObserver(entries => {
        entries.forEach(e => {
            if (e.isIntersecting) { e.target.classList.add('on'); io.unobserve(e.target); }
        });
    }, { threshold: 0.1 });
    document.querySelectorAll('[data-sr]').forEach(el => io.observe(el));
})();
</script>

@include('partials.cinematic-opening')
@livewireScripts
</body>
</html>
