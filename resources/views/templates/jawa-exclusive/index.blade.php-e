<div x-show="opened" x-cloak
     class="fixed bottom-20 left-1/2 z-40 pointer-events-none select-none"
     style="transform:translateX(-50%)"
     aria-hidden="true">
    <a href="{{ config('app.url') }}" target="_blank" rel="noopener noreferrer"
