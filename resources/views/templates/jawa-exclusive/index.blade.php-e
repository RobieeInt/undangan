                <svg viewBox="0 0 36 22" class="w-7 flex-shrink-0" fill="none">
                    <path d="M18 1 L30 11 L18 21 L6 11 Z" stroke="#C9A86A" stroke-width=".8" opacity=".65"/>
                    <circle cx="18" cy="11" r="3.5" fill="#C9A86A" opacity=".55"/>
