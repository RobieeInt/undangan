                    <path d="M0,8 C75,44 225,44 300,8" stroke="#C9A86A" stroke-width=".8" fill="none"/>
                    <use href="#jf" transform="translate(22,26)  scale(.8)"/>
                    <use href="#jf" transform="translate(75,38)  scale(.88)"/>
                    <use href="#jf" transform="translate(150,44)"/>
                    <use href="#jf" transform="translate(225,38) scale(.88)"/>
                    <use href="#jf" transform="translate(278,26) scale(.8)"/>
