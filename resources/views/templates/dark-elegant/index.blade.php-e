<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="csrf-token" content="{{ csrf_token() }}"><meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>{{ $invitation->getCoupleName() }} — Undangan Pernikahan</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css">
    {{-- swiper removed, replaced by collage --}}
    @vite(['resources/css/app.css','resources/js/app.js'])
    @livewireStyles
    @livewireScriptConfig
    <style>
        :root { --gold: #C9A84C; --dark: #0F0F0F; --dark2: #1A1A1A; }
        body { background: var(--dark); color: #E8E0CC; font-family: 'Montserrat',sans-serif; }
        .fc { font-family: 'Cormorant Garamond', serif; }
        .gold { color: var(--gold); }
        .border-gold { border-color: var(--gold) !important; }
        .line-gold { height:1px; background: linear-gradient(to right, transparent, var(--gold), transparent); }

        /* ── Global gold particle canvas ── */
        #de-global-particles { position:fixed;inset:0;pointer-events:none;z-index:92;overflow:hidden; }
        /* ── Cover + global gold particle animation ── */
        .de-particle { position:absolute; pointer-events:none; }
        @keyframes deParticleFloat {
            /* start scattered in lower viewport, travel all the way up & off-screen */
            0%   { transform:translateY(0) translateX(0) rotate(0deg); opacity:0; }
            8%   { opacity:var(--po,0.7); }
            90%  { opacity:calc(var(--po,0.7) * 0.55); }
            100% { transform:translateY(-118vh) translateX(var(--drift,30px)) rotate(var(--spin,180deg)); opacity:0; }
        }
        /* ── Bokeh canvas ── */
        #de-bokeh {
            position:absolute;inset:0;width:100%;height:100%;
            pointer-events:none;z-index:2;
        }

        /* ── Center ambient glow pulse ── */
        .de-center-glow {
            position:absolute;left:50%;top:50%;
            transform:translate(-50%,-50%);
            width:min(520px,95vw);height:min(520px,95vw);
            border-radius:50%;pointer-events:none;z-index:1;
            background:radial-gradient(circle at center,
                rgba(201,168,76,.14) 0%,
                rgba(201,168,76,.07) 35%,
                rgba(201,168,76,.02) 60%,
                transparent 75%);
            animation:deGlowPulse 5.5s ease-in-out infinite;
            will-change:transform,opacity;
        }
        @keyframes deGlowPulse {
            0%,100% { opacity:.5;  transform:translate(-50%,-50%) scale(1);    }
            50%     { opacity:1;   transform:translate(-50%,-50%) scale(1.25); }
        }

        /* ── Diagonal light sweep ── */
        .de-light-sweep {
            position:absolute;inset:0;
            background:linear-gradient(108deg,
                transparent 0%,
                rgba(201,168,76,.03)  32%,
                rgba(201,168,76,.10)  50%,
                rgba(201,168,76,.03)  68%,
                transparent 100%);
            transform:translateX(-140%);
            pointer-events:none;z-index:3;
            animation:deSweep 10s ease-in-out 1.5s infinite;
        }
        @keyframes deSweep {
            0%   { transform:translateX(-140%); opacity:0; }
            4%   { opacity:1; }
            46%  { opacity:1; }
            52%  { transform:translateX(140%);  opacity:0; }
            100% { transform:translateX(-140%); opacity:0; }
        }

        /* ── Name shimmer glow ── */
        @keyframes deNameShimmer {
            0%,100% { text-shadow:0 0 0 transparent; }
            50%     { text-shadow:0 0 36px rgba(201,168,76,.22), 0 0 72px rgba(201,168,76,.09); }
        }
        .de-shimmer { animation:deNameShimmer 6.5s ease-in-out infinite; }

        /* ── Cover corner ornament draw-in ── */
        .de-corner-line {
            stroke-dasharray: 200;
            stroke-dashoffset: 200;
            animation: deLineDraw 2s ease-out 0.3s forwards;
        }
        @keyframes deLineDraw { to { stroke-dashoffset: 0; } }
        /* ── Cover text stagger fade-up ── */
        @keyframes deFadeUp {
            from { opacity:0; transform:translateY(20px); }
            to   { opacity:1; transform:translateY(0); }
        }
        .de-in   { animation: deFadeUp 0.9s ease-out both; }
        .de-in-1 { animation-delay: 0.4s; }
        .de-in-2 { animation-delay: 0.7s; }
        .de-in-3 { animation-delay: 1.0s; }
        .de-in-4 { animation-delay: 1.3s; }
        .de-in-5 { animation-delay: 1.6s; }
    </style>
</head>
