<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    AOS.init({ duration: 900, once: true });

    // ── Gold Sparkle Particles (cover + global) ──────────────────
    (function () {
        var starSvg = '<svg viewBox="0 0 12 12" style="width:100%;height:100%">'
                    + '<path d="M6 0 L6.7 5.3 L12 6 L6.7 6.7 L6 12 L5.3 6.7 L0 6 L5.3 5.3 Z" fill="#C9A84C"/>'
                    + '</svg>';
        var dotSvg  = '<svg viewBox="0 0 8 8" style="width:100%;height:100%">'
                    + '<circle cx="4" cy="4" r="3" fill="#C9A84C" opacity=".75"/>'
                    + '</svg>';

        function spawnParticles(canvasId, N) {
            var c = document.getElementById(canvasId);
            if (!c) return;
            for (var i = 0; i < N; i++) {
                var isStar = Math.random() > 0.42;
                var size   = isStar ? (4 + Math.random() * 10) : (3 + Math.random() * 6);
                var dur    = 9 + Math.random() * 13;
                /* Negative delay scatters particles across the whole animation cycle →
                   at any moment particles are spread from bottom to top of viewport */
                var del    = -(Math.random() * dur);
                var left   = Math.random() * 100;
                /* start position: lower 40% of screen so travel covers full viewport */
                var topPct = 68 + Math.random() * 38;
                var drift  = (Math.random() - 0.5) * 80;
                var spin   = 60 + Math.random() * 300;
                /* per-particle peak opacity so some are more prominent */
                var po     = 0.45 + Math.random() * 0.55;
                var el     = document.createElement('div');
                el.className = 'de-particle';
                el.innerHTML = isStar ? starSvg : dotSvg;
                el.style.cssText =
                    'width:'   + size   + 'px;'
                  + 'height:'  + size   + 'px;'
                  + 'left:'    + left   + '%;'
                  + 'top:'     + topPct + '%;'
                  + '--drift:' + drift  + 'px;'
                  + '--spin:'  + spin   + 'deg;'
                  + '--po:'    + po     + ';'
                  + 'animation:deParticleFloat ' + dur + 's linear ' + del + 's infinite;';
                c.appendChild(el);
            }
        }

        spawnParticles('de-cover-particles', 38);  // cover screen
        spawnParticles('de-global-particles', 28); // main content overlay
    })();

    /* ── Canvas Bokeh — gold glowing orbs drift upward ── */
    (function () {
        var canvas = document.getElementById('de-bokeh');
        if (!canvas) return;
        var ctx = canvas.getContext('2d');
        var W, H;

        function resize() {
            /* Always use window dimensions — parent may be display:none briefly at init */
            W = canvas.width  = window.innerWidth;
            H = canvas.height = window.innerHeight;
        }

        function Bokeh(fresh) {
            this.reset = function (fresh) {
                this.x    = Math.random() * W;
                /* On fresh spawn come from bottom; on init scatter across full height */
                this.y    = fresh ? H + Math.random() * 60 : Math.random() * H;
                this.r    = 6 + Math.random() * 28;
                this.vy   = -(0.18 + Math.random() * 0.5);
                this.vx   = (Math.random() - 0.5) * 0.28;
                /* Increased opacity so orbs are clearly visible on dark bg */
                this.aMax = 0.10 + Math.random() * 0.22;
                this.life = fresh ? 0 : Math.floor(Math.random() * 220);
                this.twinkle = Math.random() > 0.48;
                this.ts   = 0.016 + Math.random() * 0.040;
                this.tp   = Math.random() * Math.PI * 2;
            };
            this.reset(fresh);
        }

        Bokeh.prototype.update = function () {
            this.x += this.vx + Math.sin(this.life * 0.017) * 0.36;
            this.y += this.vy;
            this.life++;
            if (this.y < -this.r * 2) this.reset(true);
        };

        Bokeh.prototype.draw = function () {
            var a = this.twinkle
                ? this.aMax * (0.42 + 0.58 * Math.sin(this.life * this.ts + this.tp))
                : this.aMax;
            /* inner bright core + outer soft halo */
            var grd = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.r);
            grd.addColorStop(0,    'rgba(220,185,90,' + a + ')');
            grd.addColorStop(0.28, 'rgba(201,168,76,' + (a * 0.7) + ')');
            grd.addColorStop(0.6,  'rgba(201,168,76,' + (a * 0.28) + ')');
            grd.addColorStop(1,    'rgba(201,168,76,0)');
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
            ctx.fillStyle = grd;
            ctx.fill();
        };

        resize();
        window.addEventListener('resize', resize);

        var bokehs = [];
        for (var i = 0; i < 32; i++) { bokehs.push(new Bokeh(false)); }

        var raf;
        function tick() {
            ctx.clearRect(0, 0, W, H);
            bokehs.forEach(function (b) { b.update(); b.draw(); });
            raf = requestAnimationFrame(tick);
        }
        tick();
    })();
</script>
</body>
</html>
